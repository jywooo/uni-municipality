VITE_APP_NAME=Municipality Events
VITE_DATA_PROVIDER=mock

# Backend API base URL when using a CMS or custom backend.
VITE_API_BASE_URL=http://localhost:1337/api
VITE_API_TOKEN=

# Auth endpoint expected to return { user, token } or { data: { user, token } }.
VITE_AUTH_LOGIN_ENDPOINT=/auth/login

# Resource endpoints. These can point to Strapi, Directus, a custom CMS,
# or any REST backend that returns either arrays or { data: [...] }.
VITE_CMS_EVENTS_ENDPOINT=/events
VITE_CMS_REGISTRATIONS_ENDPOINT=/registrations
VITE_CMS_USERS_ENDPOINT=/users
VITE_CMS_VENUES_ENDPOINT=/venues
VITE_CMS_CATEGORIES_ENDPOINT=/categories
VITE_CMS_NOTIFICATIONS_ENDPOINT=/notifications
